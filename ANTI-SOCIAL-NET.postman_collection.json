		{
			"name": "Follow",
			"item": [
				{
					"name": "Follow User",
					"request": {
						"method": "POST",
						"header": [
							{ "key": "Content-Type", "value": "application/json" }
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"follower_nickName\": \"john_doe\",\n  \"following_nickName\": \"jane_doe\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/follow",
							"host": ["{{baseUrl}}"],
							"path": ["follow"]
